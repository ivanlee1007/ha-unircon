# EMOS backup worker wrapper example env

# Root working directory
EMOS_BACKUP_ROOT=/share/emostore

# Optional explicit git repo path
# EMOS_BACKUP_REPO=/share/emostore/repo

# Optional serial -> host mapping json
# EMOS_BACKUP_HOST_MAP=/config/ha-unircon/host-map.json

# Push after successful scan+commit
EMOS_BACKUP_PUSH=0

# Git remote / branch when push is enabled
EMOS_BACKUP_GIT_REMOTE=origin
EMOS_BACKUP_GIT_BRANCH=main

# Debug / validation mode
EMOS_BACKUP_DRY_RUN=0
