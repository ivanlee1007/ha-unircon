# HA -> binding-map -> backup worker pipeline example env

# Home Assistant API
HA_URL=http://homeassistant.local:8123
HA_TOKEN=replace_with_long_lived_access_token

# Optional host subset, comma-separated. Empty = all configured hosts.
# PIPELINE_HOSTS=Relay-685D,sensor01

# Skip health check if you only want to refresh/save binding map + run worker
PIPELINE_SKIP_HEALTH_CHECK=0

# Wait after run_health_check before saving binding map
PIPELINE_HEALTH_WAIT_SECONDS=15

# Wait for save_binding_map output file to appear
PIPELINE_FILE_WAIT_SECONDS=20

# File path written by HA service (config-relative)
PIPELINE_BINDING_MAP_SERVICE_PATH=unircon/binding-map.generated.json

# Same file as seen by the host-side runner
PIPELINE_BINDING_MAP_PATH=/config/unircon/binding-map.generated.json

# Allow save_binding_map to replace existing file
PIPELINE_OVERWRITE_BINDING_MAP=1

# Dry-run: call HA services but do not invoke worker wrapper
PIPELINE_DRY_RUN=0

# Worker / repo settings still come from the existing wrapper env
EMOS_BACKUP_ROOT=/share/emostore
EMOS_BACKUP_PUSH=0
EMOS_BACKUP_GIT_REMOTE=origin
EMOS_BACKUP_GIT_BRANCH=main
